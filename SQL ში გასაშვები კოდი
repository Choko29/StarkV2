USE app_db;

-- ვშლით ძველ ცხრილს, რომ ახალი სტრუქტურით გადაიწეროს
DROP TABLE IF EXISTS app_table;

CREATE TABLE app_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    item_name VARCHAR(255) NOT NULL,
    item_value1 VARCHAR(255) NOT NULL, -- 🌟 გახდა VARCHAR (იტევს ფასსაც, კატეგორიასაც და თარიღსაც)
    item_value2 INT NOT NULL           -- 🌟 დარჩა INT მკაცრად რაოდენობისთვის (ჩარტის ასაგებად)
);
